<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AquaShine Car Wash — Premium Auto Detailing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --navy:    #0a1628;
  --blue:    #1254a4;
  --sky:     #2d8bde;
  --aqua:    #00c6ff;
  --ice:     #e8f4fd;
  --white:   #ffffff;
  --soft:    #f5f9fe;
  --muted:   #6b8aaa;
  --gold:    #f5a623;
  --radius:  16px;
  --shadow:  0 20px 60px rgba(10,22,40,0.15);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Outfit',sans-serif;
  color:var(--navy);
  background:var(--white);
  overflow-x:hidden;
}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}

/* ── WATER RIPPLE SVG BACKGROUND ── */
.water-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 120% 80% at 50% 110%, rgba(0,198,255,0.18) 0%, transparent 60%),
    radial-gradient(ellipse 80% 60% at 80% 20%, rgba(18,84,164,0.12) 0%, transparent 50%),
    linear-gradient(160deg, #0a1628 0%, #0d2247 50%, #0f2f5c 100%);
}

/* animated wave lines */
.wave-lines{
  position:absolute;bottom:0;left:0;right:0;overflow:hidden;line-height:0;
}
.wave-lines svg{width:100%;height:80px;fill:var(--white);}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 6%;
  transition:background 0.3s,box-shadow 0.3s;
}
nav.scrolled{
  background:rgba(10,22,40,0.95);
  backdrop-filter:blur(16px);
  box-shadow:0 2px 30px rgba(0,0,0,0.25);
}
.nav-logo{
  display:flex;align-items:center;gap:10px;
  font-family:'Playfair Display',serif;
  font-size:1.4rem;font-weight:700;
  color:var(--white);
}
.nav-logo-icon{
  width:38px;height:38px;border-radius:10px;
  background:linear-gradient(135deg,var(--sky),var(--aqua));
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;box-shadow:0 4px 14px rgba(0,198,255,0.4);
}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{
  color:rgba(255,255,255,0.8);font-size:0.9rem;font-weight:500;
  transition:color 0.2s;
}
.nav-links a:hover{color:var(--aqua);}
.nav-btn{
  background:linear-gradient(135deg,var(--sky),var(--aqua));
  color:var(--white);padding:10px 24px;border-radius:50px;
  font-weight:600;font-size:0.875rem;
  box-shadow:0 4px 20px rgba(0,198,255,0.35);
  transition:transform 0.2s,box-shadow 0.2s;
}
.nav-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,198,255,0.5);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
.hamburger span{width:24px;height:2px;background:#fff;border-radius:2px;transition:all 0.3s;}
.mobile-nav{
  display:none;position:fixed;inset:0;background:var(--navy);z-index:190;
  flex-direction:column;align-items:center;justify-content:center;gap:32px;
}
.mobile-nav.open{display:flex;}
.mobile-nav a{color:#fff;font-size:1.4rem;font-weight:600;}

/* ── HERO ── */
.hero{
  position:relative;min-height:100vh;
  display:flex;align-items:center;
  padding:120px 6% 100px;
  overflow:hidden;
}
.water-bg{z-index:0;}

/* Animated droplets */
.droplet{
  position:absolute;border-radius:50%;
  background:rgba(0,198,255,0.12);
  animation:float 8s ease-in-out infinite;
}
.droplet:nth-child(1){width:300px;height:300px;top:10%;right:5%;animation-delay:0s;}
.droplet:nth-child(2){width:180px;height:180px;top:60%;right:20%;animation-delay:2s;}
.droplet:nth-child(3){width:120px;height:120px;top:20%;left:5%;animation-delay:4s;}

@keyframes float{
  0%,100%{transform:translateY(0) scale(1);}
  50%{transform:translateY(-20px) scale(1.05);}
}

.hero-content{position:relative;z-index:2;max-width:620px;}

.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(0,198,255,0.15);
  border:1px solid rgba(0,198,255,0.3);
  color:var(--aqua);
  border-radius:50px;padding:7px 18px;
  font-size:0.8rem;font-weight:600;letter-spacing:0.08em;
  text-transform:uppercase;margin-bottom:28px;
}
.hero-badge::before{content:'💧';font-size:0.9rem;}

.hero h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(2.6rem,5.5vw,4.2rem);
  font-weight:900;
  color:var(--white);
  line-height:1.12;
  margin-bottom:22px;
  letter-spacing:-0.02em;
}
.hero h1 .shine{
  background:linear-gradient(90deg,var(--aqua),#7dd3fc);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.hero p{
  color:rgba(255,255,255,0.65);
  font-size:1.15rem;font-weight:300;
  line-height:1.7;margin-bottom:44px;
  max-width:480px;
}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;}

.btn-primary{
  background:linear-gradient(135deg,var(--sky),var(--aqua));
  color:#fff;padding:15px 34px;
  border-radius:50px;font-weight:700;font-size:1rem;
  box-shadow:0 6px 28px rgba(0,198,255,0.4);
  transition:transform 0.2s,box-shadow 0.2s;
  display:inline-flex;align-items:center;gap:8px;
}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(0,198,255,0.55);}

.btn-ghost{
  background:rgba(255,255,255,0.08);
  color:#fff;padding:15px 34px;
  border-radius:50px;font-weight:600;font-size:1rem;
  border:1.5px solid rgba(255,255,255,0.2);
  transition:all 0.2s;
}
.btn-ghost:hover{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.4);}

/* hero car visual */
.hero-visual{
  position:absolute;right:0;top:50%;transform:translateY(-50%);
  width:55%;max-width:800px;z-index:1;
  pointer-events:none;
}
.hero-car-frame{
  position:relative;
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:28px;
  overflow:hidden;
  aspect-ratio:16/10;
  box-shadow:0 40px 100px rgba(0,0,0,0.4);
  margin-right:-40px;
}
.car-svg-wrapper{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,#0d1f3c 0%,#162d52 50%,#0d2547 100%);
}

/* Inline car SVG illustration */
.car-scene{width:90%;max-width:580px;}

/* Spray particles */
.spray{
  position:absolute;top:0;left:0;right:0;bottom:0;
  background:
    radial-gradient(circle 2px at 20% 30%, rgba(0,198,255,0.8) 0%, transparent 2px),
    radial-gradient(circle 1px at 35% 20%, rgba(125,211,252,0.6) 0%, transparent 1px),
    radial-gradient(circle 2px at 15% 45%, rgba(0,198,255,0.5) 0%, transparent 2px),
    radial-gradient(circle 1px at 70% 25%, rgba(125,211,252,0.7) 0%, transparent 1px),
    radial-gradient(circle 2px at 80% 40%, rgba(0,198,255,0.4) 0%, transparent 2px),
    radial-gradient(circle 1px at 60% 55%, rgba(125,211,252,0.6) 0%, transparent 1px);
  animation:spray-anim 3s ease-in-out infinite;
  pointer-events:none;
}
@keyframes spray-anim{
  0%,100%{opacity:0.4;}
  50%{opacity:1;}
}

.hero-stats{
  display:flex;gap:36px;margin-top:52px;flex-wrap:wrap;
}
.stat{border-left:2px solid rgba(0,198,255,0.4);padding-left:14px;}
.stat-num{
  font-family:'Playfair Display',serif;
  font-size:1.8rem;font-weight:800;color:var(--white);
  line-height:1;margin-bottom:4px;
}
.stat-label{font-size:0.8rem;color:rgba(255,255,255,0.5);font-weight:400;letter-spacing:0.04em;}

/* ── SECTION COMMONS ── */
section{padding:100px 6%;}
.section-label{
  font-size:0.75rem;font-weight:700;letter-spacing:0.14em;
  text-transform:uppercase;color:var(--sky);margin-bottom:12px;
}
.section-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,3.5vw,2.8rem);
  font-weight:800;line-height:1.2;
  letter-spacing:-0.02em;margin-bottom:14px;
}
.section-sub{
  color:var(--muted);font-size:1rem;font-weight:300;
  line-height:1.8;max-width:520px;margin-bottom:60px;
}
.center{text-align:center;}
.center .section-sub{margin-left:auto;margin-right:auto;}

/* ── SERVICES ── */
#services{background:var(--soft);}

.services-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:24px;
}
.svc-card{
  background:var(--white);
  border-radius:var(--radius);
  padding:38px 30px;
  border:1px solid rgba(18,84,164,0.08);
  position:relative;overflow:hidden;
  transition:transform 0.3s,box-shadow 0.3s;
}
.svc-card:hover{transform:translateY(-8px);box-shadow:var(--shadow);}

.svc-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
}
.svc-card:nth-child(1)::before{background:linear-gradient(90deg,var(--sky),var(--aqua));}
.svc-card:nth-child(2)::before{background:linear-gradient(90deg,#0052a4,var(--sky));}
.svc-card:nth-child(3)::before{background:linear-gradient(90deg,var(--aqua),#38bdf8);}
.svc-card:nth-child(4)::before{background:linear-gradient(90deg,var(--gold),#fbbf24);}

.svc-icon{
  width:56px;height:56px;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.6rem;margin-bottom:22px;
}
.svc-icon-1{background:rgba(45,139,222,0.1);}
.svc-icon-2{background:rgba(0,82,164,0.08);}
.svc-icon-3{background:rgba(0,198,255,0.1);}
.svc-icon-4{background:rgba(245,166,35,0.1);}

.svc-card h3{font-size:1.15rem;font-weight:700;margin-bottom:10px;}
.svc-card p{color:var(--muted);font-size:0.9rem;font-weight:300;line-height:1.7;margin-bottom:22px;}
.svc-price{
  display:inline-flex;align-items:baseline;gap:4px;
  font-family:'Playfair Display',serif;
}
.svc-price-from{font-size:0.78rem;color:var(--muted);font-family:'Outfit',sans-serif;font-weight:400;}
.svc-price-num{font-size:1.8rem;font-weight:800;color:var(--blue);}
.svc-price-per{font-size:0.82rem;color:var(--muted);font-family:'Outfit',sans-serif;}

.svc-btn{
  display:inline-block;margin-top:20px;
  padding:10px 22px;border-radius:50px;
  font-size:0.85rem;font-weight:600;
  background:var(--ice);color:var(--blue);
  transition:all 0.2s;
}
.svc-btn:hover{background:var(--blue);color:#fff;}

/* ── WHY US ── */
#why{
  background:var(--navy);
  position:relative;overflow:hidden;
}
#why::before{
  content:'';position:absolute;
  width:700px;height:700px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,198,255,0.07) 0%,transparent 70%);
  top:-200px;right:-200px;
}
.why-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:56px;
  align-items:center;
}
.why-left .section-title,.why-left .section-label{color:var(--white);}
.why-left .section-title span{
  background:linear-gradient(90deg,var(--aqua),#7dd3fc);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.why-left .section-sub{color:rgba(255,255,255,0.5);}

.why-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.why-card{
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:var(--radius);padding:26px 22px;
  transition:background 0.3s;
}
.why-card:hover{background:rgba(255,255,255,0.09);}
.why-icon{font-size:1.8rem;margin-bottom:14px;}
.why-card h4{color:#fff;font-size:1rem;font-weight:700;margin-bottom:8px;}
.why-card p{color:rgba(255,255,255,0.45);font-size:0.875rem;font-weight:300;line-height:1.6;}

/* ── PRICING ── */
#pricing{background:var(--soft);}

.pricing-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:24px;max-width:1000px;margin:0 auto;
}
.plan-card{
  background:var(--white);
  border:1px solid rgba(18,84,164,0.1);
  border-radius:24px;
  padding:42px 36px;
  position:relative;
  transition:transform 0.3s,box-shadow 0.3s;
}
.plan-card:hover{transform:translateY(-6px);}
.plan-card.featured{
  background:linear-gradient(160deg,#0d2247,#1254a4);
  border-color:transparent;
  box-shadow:0 24px 70px rgba(18,84,164,0.45);
  color:#fff;
}
.plan-card.featured::before{
  content:'';position:absolute;inset:-1px;
  border-radius:25px;z-index:-1;
  background:linear-gradient(135deg,var(--aqua),var(--blue));
  opacity:0.3;
}
.popular-badge{
  display:inline-block;
  background:linear-gradient(135deg,var(--sky),var(--aqua));
  color:#fff;font-size:0.7rem;font-weight:700;
  letter-spacing:0.06em;text-transform:uppercase;
  padding:5px 14px;border-radius:50px;
  margin-bottom:22px;
}
.plan-name{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:800;margin-bottom:8px;}
.plan-desc{font-size:0.9rem;color:var(--muted);font-weight:300;margin-bottom:28px;line-height:1.6;}
.plan-card.featured .plan-desc{color:rgba(255,255,255,0.55);}
.plan-price-wrap{margin-bottom:32px;}
.plan-price{
  font-family:'Playfair Display',serif;
  font-size:3.2rem;font-weight:900;line-height:1;
}
.plan-price span{font-family:'Outfit',sans-serif;font-size:1rem;font-weight:400;color:var(--muted);margin-left:4px;}
.plan-card.featured .plan-price span{color:rgba(255,255,255,0.5);}
.plan-divider{height:1px;background:rgba(18,84,164,0.1);margin-bottom:28px;}
.plan-card.featured .plan-divider{background:rgba(255,255,255,0.12);}
.plan-features{list-style:none;margin-bottom:36px;}
.plan-feature{
  display:flex;align-items:center;gap:10px;
  padding:8px 0;font-size:0.9rem;color:var(--muted);
}
.plan-card.featured .plan-feature{color:rgba(255,255,255,0.65);}
.plan-feature::before{
  content:'✓';
  width:20px;height:20px;border-radius:50%;flex-shrink:0;
  background:rgba(0,198,255,0.12);color:var(--aqua);
  display:flex;align-items:center;justify-content:center;
  font-size:0.7rem;font-weight:700;
}
.plan-btn{
  display:block;text-align:center;
  padding:14px;border-radius:50px;
  font-weight:700;font-size:0.95rem;
  transition:all 0.2s;
}
.plan-btn-outline{border:2px solid rgba(18,84,164,0.2);color:var(--blue);}
.plan-btn-outline:hover{background:var(--blue);color:#fff;border-color:var(--blue);}
.plan-btn-glow{
  background:linear-gradient(135deg,var(--sky),var(--aqua));
  color:#fff;
  box-shadow:0 6px 24px rgba(0,198,255,0.4);
}
.plan-btn-glow:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(0,198,255,0.55);}

/* ── REVIEWS ── */
#reviews{background:var(--white);}
.reviews-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:24px;
}
.review-card{
  background:var(--soft);
  border:1px solid rgba(18,84,164,0.07);
  border-radius:var(--radius);
  padding:34px 28px;
  position:relative;
  transition:transform 0.3s,box-shadow 0.3s;
}
.review-card:hover{transform:translateY(-5px);box-shadow:var(--shadow);}
.review-card::before{
  content:'"';
  font-family:'Playfair Display',serif;
  font-size:5rem;font-weight:900;
  color:rgba(45,139,222,0.1);
  position:absolute;top:-10px;left:22px;
  line-height:1;
}
.stars{color:var(--gold);font-size:0.9rem;letter-spacing:3px;margin-bottom:16px;}
.review-text{
  font-size:0.95rem;line-height:1.75;
  color:var(--navy);margin-bottom:24px;
  font-weight:400;
}
.review-author{display:flex;align-items:center;gap:12px;}
.author-av{
  width:44px;height:44px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:1rem;color:#fff;flex-shrink:0;
}
.author-name{font-weight:700;font-size:0.92rem;}
.author-info{font-size:0.8rem;color:var(--muted);}

/* ── CONTACT ── */
#contact{
  background:var(--navy);
  position:relative;overflow:hidden;
}
#contact::before{
  content:'';position:absolute;
  width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,198,255,0.06) 0%,transparent 70%);
  bottom:-150px;left:-150px;
}
.contact-grid{
  display:grid;
  grid-template-columns:1fr 1.2fr;
  gap:60px;align-items:start;
}
.contact-info .section-title,.contact-info .section-label{color:#fff;}
.contact-info .section-title span{
  background:linear-gradient(90deg,var(--aqua),#7dd3fc);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.contact-info .section-sub{color:rgba(255,255,255,0.5);margin-bottom:36px;}

.contact-detail{
  display:flex;align-items:flex-start;gap:16px;
  margin-bottom:22px;
}
.contact-icon{
  width:44px;height:44px;border-radius:12px;
  background:rgba(0,198,255,0.1);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0;
}
.contact-text h4{color:#fff;font-weight:600;font-size:0.9rem;margin-bottom:3px;}
.contact-text p{color:rgba(255,255,255,0.5);font-size:0.9rem;font-weight:300;}

.map-placeholder{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:var(--radius);
  height:200px;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:10px;
  margin-top:28px;
  font-size:1.5rem;
  color:rgba(255,255,255,0.3);
  font-size:0.9rem;
  overflow:hidden;
  position:relative;
}
.map-placeholder iframe{
  position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:var(--radius);opacity:0.8;
}

/* contact form */
.contact-form{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:24px;
  padding:42px 38px;
  position:relative;z-index:1;
}
.contact-form h3{
  font-family:'Playfair Display',serif;
  font-size:1.4rem;font-weight:800;
  color:#fff;margin-bottom:26px;
}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{margin-bottom:18px;}
label{
  display:block;color:rgba(255,255,255,0.5);
  font-size:0.8rem;font-weight:500;
  letter-spacing:0.04em;text-transform:uppercase;
  margin-bottom:8px;
}
input,select,textarea{
  width:100%;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:10px;
  padding:13px 16px;
  color:#fff;font-family:'Outfit',sans-serif;font-size:0.95rem;
  transition:border-color 0.2s,background 0.2s;
  outline:none;
}
input::placeholder,textarea::placeholder{color:rgba(255,255,255,0.3);}
input:focus,select:focus,textarea:focus{
  border-color:var(--aqua);
  background:rgba(0,198,255,0.07);
}
select option{background:var(--navy);color:#fff;}
textarea{resize:vertical;min-height:110px;}
.form-submit{
  width:100%;padding:15px;border-radius:50px;
  background:linear-gradient(135deg,var(--sky),var(--aqua));
  color:#fff;font-weight:700;font-size:1rem;
  border:none;cursor:pointer;
  box-shadow:0 6px 24px rgba(0,198,255,0.35);
  transition:transform 0.2s,box-shadow 0.2s;
  font-family:'Outfit',sans-serif;
  margin-top:8px;
}
.form-submit:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(0,198,255,0.5);}

/* ── FOOTER ── */
footer{
  background:#06101e;
  padding:56px 6% 32px;
  color:rgba(255,255,255,0.55);
}
.footer-grid{
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1fr;
  gap:48px;
  padding-bottom:44px;
  border-bottom:1px solid rgba(255,255,255,0.07);
  margin-bottom:28px;
}
.footer-brand .nav-logo{margin-bottom:14px;}
.footer-brand p{font-size:0.875rem;line-height:1.75;max-width:250px;font-weight:300;}
.social-row{display:flex;gap:10px;margin-top:22px;}
.soc{
  width:38px;height:38px;border-radius:50%;
  border:1px solid rgba(255,255,255,0.1);
  display:flex;align-items:center;justify-content:center;
  font-size:0.9rem;
  transition:all 0.2s;
}
.soc:hover{background:var(--sky);border-color:var(--sky);color:#fff;}
.footer-col h4{
  font-size:0.78rem;font-weight:700;letter-spacing:0.1em;
  text-transform:uppercase;color:rgba(255,255,255,0.3);
  margin-bottom:16px;
}
.footer-col ul{list-style:none;}
.footer-col li{margin-bottom:10px;}
.footer-col a{font-size:0.875rem;font-weight:300;transition:color 0.2s;}
.footer-col a:hover{color:var(--aqua);}

.hours-row{display:flex;justify-content:space-between;font-size:0.875rem;font-weight:300;margin-bottom:8px;}
.hours-row span:first-child{color:rgba(255,255,255,0.4);}
.hours-open{color:var(--aqua);font-weight:600;}

.footer-bottom{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:12px;
  font-size:0.8rem;color:rgba(255,255,255,0.25);
}
.footer-bottom a{color:rgba(255,255,255,0.35);}
.footer-bottom a:hover{color:var(--aqua);}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.in{opacity:1;transform:none;}

/* ── RESPONSIVE ── */
@media(max-width:992px){
  .why-grid,.contact-grid{grid-template-columns:1fr;}
  .hero-visual{display:none;}
  .hero-content{max-width:100%;}
  .footer-grid{grid-template-columns:1fr 1fr;}
}
@media(max-width:640px){
  .nav-links,.nav-btn{display:none;}
  .hamburger{display:flex;}
  .hero{padding:100px 5% 72px;}
  section{padding:72px 5%;}
  .form-row{grid-template-columns:1fr;}
  .footer-grid{grid-template-columns:1fr;}
  .why-cards{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ── MOBILE NAV ── -->
