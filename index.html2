</nav>

<!-- ── HERO ── -->
<section class="hero" id="hero">
  <div class="water-bg"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>
  <div class="droplet"></div>

  <div class="hero-content">
    <div class="hero-badge">Trusted by 10,000+ car owners</div>
    <h1>Premium Car Wash<br>That Makes Your<br>Car <span class="shine">Shine</span></h1>
    <p>Fast, affordable, and professional car cleaning services. Your vehicle deserves the best — we deliver nothing less.</p>
    <div class="hero-btns">
      <a href="#contact" class="btn-primary">📅 Book Now</a>
      <a href="#services" class="btn-ghost">View Services ↓</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">10K+</div>
        <div class="stat-label">Happy Customers</div>
      </div>
      <div class="stat">
        <div class="stat-num">8 Yrs</div>
        <div class="stat-label">In Business</div>
      </div>
      <div class="stat">
        <div class="stat-num">4.9★</div>
        <div class="stat-label">Average Rating</div>
      </div>
    </div>
  </div>

  <!-- Hero car illustration -->
  <div class="hero-visual">
    <div class="hero-car-frame">
      <div class="car-svg-wrapper">
        <div class="spray"></div>
        <svg class="car-scene" viewBox="0 0 580 360" xmlns="http://www.w3.org/2000/svg">
          <!-- Ground reflection -->
          <ellipse cx="290" cy="330" rx="220" ry="18" fill="rgba(0,198,255,0.12)"/>
          <!-- Car body -->
          <g transform="translate(40, 120)">
            <!-- Main body -->
            <rect x="30" y="80" width="440" height="100" rx="14" fill="#1a3a6e"/>
            <!-- Cabin -->
            <path d="M100 80 L150 30 Q170 20 200 20 L330 20 Q360 20 380 30 L420 80 Z" fill="#1e4a8a" stroke="rgba(0,198,255,0.15)" stroke-width="1"/>
            <!-- Windows -->
            <path d="M160 75 L190 38 Q200 30 215 30 L260 30 L260 75 Z" fill="rgba(0,198,255,0.2)" rx="4"/>
            <path d="M270 30 L325 30 Q338 30 348 38 L375 75 L270 75 Z" fill="rgba(0,198,255,0.2)" rx="4"/>
            <!-- Window shine -->
            <path d="M175 70 L198 42 L215 38 L215 50 L200 70 Z" fill="rgba(255,255,255,0.12)"/>
            <!-- Door lines -->
            <line x1="270" y1="80" x2="270" y2="175" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
            <!-- Door handles -->
            <rect x="220" y="125" width="28" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
            <rect x="300" y="125" width="28" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
            <!-- Headlights -->
            <rect x="15" y="90" width="30" height="16" rx="6" fill="#00c6ff" opacity="0.8"/>
            <rect x="20" y="94" width="18" height="8" rx="3" fill="rgba(255,255,255,0.6)"/>
            <rect x="450" y="90" width="30" height="16" rx="6" fill="#ff6b35" opacity="0.7"/>
            <!-- Front grille -->
            <rect x="10" y="110" width="40" height="20" rx="5" fill="rgba(0,0,0,0.4)"/>
            <line x1="18" y1="116" x2="42" y2="116" stroke="rgba(0,198,255,0.4)" stroke-width="1.5"/>
            <line x1="18" y1="122" x2="42" y2="122" stroke="rgba(0,198,255,0.4)" stroke-width="1.5"/>
            <!-- Wheels -->
            <circle cx="130" cy="183" r="38" fill="#111827"/>
            <circle cx="130" cy="183" r="28" fill="#1f2937"/>
            <circle cx="130" cy="183" r="14" fill="#374151"/>
            <circle cx="130" cy="183" r="5" fill="#9ca3af"/>
            <!-- Wheel shine -->
            <path d="M116 169 Q126 160 136 163" stroke="rgba(255,255,255,0.15)" stroke-width="2" fill="none"/>

            <circle cx="370" cy="183" r="38" fill="#111827"/>
            <circle cx="370" cy="183" r="28" fill="#1f2937"/>
            <circle cx="370" cy="183" r="14" fill="#374151"/>
            <circle cx="370" cy="183" r="5" fill="#9ca3af"/>
            <path d="M356 169 Q366 160 376 163" stroke="rgba(255,255,255,0.15)" stroke-width="2" fill="none"/>
            <!-- Body shine -->
            <path d="M100 85 Q200 70 350 75 Q400 77 415 82" stroke="rgba(255,255,255,0.18)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <!-- Water droplets on car -->
            <circle cx="180" cy="50" r="3" fill="rgba(0,198,255,0.7)"/>
            <circle cx="250" cy="40" r="2" fill="rgba(0,198,255,0.5)"/>
            <circle cx="310" cy="48" r="3.5" fill="rgba(0,198,255,0.6)"/>
            <circle cx="200" cy="100" r="2.5" fill="rgba(0,198,255,0.4)"/>
            <circle cx="350" cy="95" r="2" fill="rgba(0,198,255,0.6)"/>
          </g>
          <!-- Water spray from left -->
          <g opacity="0.6">
            <line x1="20" y1="160" x2="80" y2="200" stroke="rgba(0,198,255,0.5)" stroke-width="2" stroke-dasharray="4 3"/>
            <line x1="15" y1="180" x2="75" y2="210" stroke="rgba(0,198,255,0.4)" stroke-width="1.5" stroke-dasharray="3 4"/>
            <line x1="25" y1="140" x2="75" y2="180" stroke="rgba(125,211,252,0.5)" stroke-width="2" stroke-dasharray="4 3"/>
          </g>
          <!-- Water spray from right -->
          <g opacity="0.6">
            <line x1="560" y1="160" x2="500" y2="200" stroke="rgba(0,198,255,0.5)" stroke-width="2" stroke-dasharray="4 3"/>
            <line x1="565" y1="180" x2="505" y2="210" stroke="rgba(0,198,255,0.4)" stroke-width="1.5" stroke-dasharray="3 4"/>
          </g>
          <!-- Foam/bubbles -->
          <circle cx="150" cy="220" r="4" fill="rgba(255,255,255,0.15)"/>
          <circle cx="170" cy="230" r="6" fill="rgba(255,255,255,0.1)"/>
          <circle cx="310" cy="215" r="5" fill="rgba(255,255,255,0.12)"/>
          <circle cx="400" cy="225" r="4" fill="rgba(255,255,255,0.15)"/>
          <!-- Floor water puddle -->
          <ellipse cx="290" cy="310" rx="200" ry="12" fill="rgba(0,198,255,0.08)"/>
          <text x="290" y="350" text-anchor="middle" fill="rgba(0,198,255,0.25)" font-size="11" font-family="Outfit,sans-serif" font-weight="600" letter-spacing="3">AQUASHINE CAR WASH</text>
        </svg>
      </div>
    </div>
  </div>

  <div class="wave-lines">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"/>
    </svg>
  </div>
</section>

<!-- ── SERVICES ── -->
<section id="services">
  <div class="center">
    <div class="section-label reveal">Our Services</div>
    <h2 class="section-title reveal">Everything Your Car Needs</h2>
    <p class="section-sub reveal">From a quick rinse to a full detail transformation — we've got a service for every need and budget.</p>
  </div>
  <div class="services-grid">
    <div class="svc-card reveal">
      <div class="svc-icon svc-icon-1">🚿</div>
      <h3>Exterior Wash</h3>
      <p>Full exterior rinse, foam wash, high-pressure clean, and spot-free rinse. Removes road grime, dust, and surface dirt — leaving a brilliant shine.</p>
      <div class="svc-price">
        <span class="svc-price-from">from</span>
        <span class="svc-price-num">$15</span>
        <span class="svc-price-per">/visit</span>
      </div>
      <a href="#contact" class="svc-btn">Book Now →</a>
    </div>
    <div class="svc-card reveal">
      <div class="svc-icon svc-icon-2">🪑</div>
      <h3>Interior Cleaning</h3>
      <p>Deep vacuum, dashboard wipe-down, door panels, console cleaning, and window cleaning inside. Your cabin will feel fresh and spotless.</p>
      <div class="svc-price">
        <span class="svc-price-from">from</span>
        <span class="svc-price-num">$25</span>
        <span class="svc-price-per">/visit</span>
      </div>
      <a href="#contact" class="svc-btn">Book Now →</a>
    </div>
    <div class="svc-card reveal">
      <div class="svc-icon svc-icon-3">✨</div>
      <h3>Full Car Detailing</h3>
      <p>Complete interior + exterior treatment. Paint decontamination, clay bar, multi-step machine polish, and sealant. Showroom condition guaranteed.</p>
      <div class="svc-price">
        <span class="svc-price-from">from</span>
        <span class="svc-price-num">$120</span>
        <span class="svc-price-per">/visit</span>
      </div>
      <a href="#contact" class="svc-btn">Book Now →</a>
    </div>
    <div class="svc-card reveal">
      <div class="svc-icon svc-icon-4">🪄</div>
      <h3>Wax & Polish</h3>
      <p>Premium carnauba wax or paint sealant application for long-lasting protection, deep gloss, and a mirror-like reflective finish you'll love.</p>
      <div class="svc-price">
        <span class="svc-price-from">from</span>
        <span class="svc-price-num">$45</span>
        <span class="svc-price-per">/visit</span>
      </div>
      <a href="#contact" class="svc-btn">Book Now →</a>
    </div>
  </div>
</section>

<!-- ── WHY US ── -->
<section id="why">
  <div class="why-grid">
    <div class="why-left">
      <div class="section-label reveal">Why AquaShine</div>
      <h2 class="section-title reveal">The Standard <span>Others</span> Aspire To</h2>
      <p class="section-sub reveal">We've built our reputation on three things: immaculate results, genuine care for your car, and a service experience that keeps you coming back.</p>
      <a href="#contact" class="btn-primary reveal" style="display:inline-flex">Get Started Today →</a>
    </div>
    <div class="why-cards">
      <div class="why-card reveal">
        <div class="why-icon">👨‍🔧</div>
        <h4>Professional Staff</h4>
        <p>Trained, certified technicians who treat your car like their own. Every wash is quality-checked before handoff.</p>
      </div>
      <div class="why-card reveal">
        <div class="why-icon">🌱</div>
        <h4>Eco-Friendly Products</h4>
        <p>Biodegradable, non-toxic cleaning agents that are tough on dirt, gentle on your car's paint, and kind to the planet.</p>
      </div>
      <div class="why-card reveal">
        <div class="why-icon">💰</div>
        <h4>Affordable Pricing</h4>
        <p>Premium results shouldn't break the bank. Transparent, competitive pricing with no hidden surprises at checkout.</p>
      </div>
      <div class="why-card reveal">
        <div class="why-icon">⚡</div>
        <h4>Fast Service</h4>
        <p>Most washes completed in under 30 minutes. We value your time as much as you do — zero unnecessary delays.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── PRICING ── -->
<section id="pricing">
  <div class="center">
    <div class="section-label reveal">Pricing Plans</div>
    <h2 class="section-title reveal">Pick Your Perfect Clean</h2>
    <p class="section-sub reveal">Simple, transparent pricing. No upsells, no surprises. Just a sparkling clean car.</p>
  </div>
  <div class="pricing-grid">
