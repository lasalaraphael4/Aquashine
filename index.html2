      <div class="plan-price-wrap">
        <div class="plan-price">$120 <span>per session</span></div>
      </div>
      <div class="plan-divider"></div>
      <ul class="plan-features">
        <li class="plan-feature">Everything in Premium</li>
        <li class="plan-feature">Clay bar decontamination</li>
        <li class="plan-feature">Machine polish (1-step)</li>
